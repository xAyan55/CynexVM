// Prisma Schema for CynexVM Control Panel
// For SQLite (Development): Use provider = "sqlite"
// For PostgreSQL (Production): Change to provider = "postgresql"

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// User & Access Control System
model User {
  id                 String              @id @default(uuid())
  username           String              @unique
  email              String              @unique
  passwordHash       String
  twoFactorSecret    String?
  twoFactorEnabled   Boolean             @default(false)
  emailVerified      Boolean             @default(false)
  emailVerifyToken   String?
  resetPasswordToken String?
  resetTokenExpires  DateTime?
  lockedUntil        DateTime?
  loginAttempts      Int                 @default(0)
  passwordChangedAt  DateTime            @default(now())
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  sessions           Session[]
  apiKeys            ApiKey[]
  auditLogs          AuditLog[]
  passwordHistories  PasswordHistory[]
  trustedDevices     TrustedDevice[]
  groupMemberships   UserGroupMember[]
  roles              UserRole[]
  instances          Instance[]
  automationTasks    AutomationTask[]
  notifications      Notification[]
  notificationPreference NotificationPreference?
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique // e.g. "Admin", "Billing", "Developer"
  description     String?
  permissions     RolePermission[]
  users           UserRole[]
  groups          RoleGroup[]
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique // e.g. "instance.start", "node.create"
  description     String?
  groupId         String
  group           PermissionGroup  @relation(fields: [groupId], references: [id])
  roles           RolePermission[]
}

model PermissionGroup {
  id          String       @id @default(uuid())
  name        String       @unique // e.g. "Virtualization", "Billing", "User Management"
  description String?
  permissions Permission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model UserGroup {
  id          String            @id @default(uuid())
  name        String            @unique
  description String?
  members     UserGroupMember[]
  roles       RoleGroup[]
}

model UserGroupMember {
  userId  String
  groupId String
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

model RoleGroup {
  roleId  String
  groupId String
  role    Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  group   UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([roleId, groupId])
}

model PasswordHistory {
  id           String   @id @default(uuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  refreshToken String   @unique
  ipAddress    String?
  userAgent    String?
  deviceId     String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TrustedDevice {
  id          String   @id @default(uuid())
  userId      String
  deviceId    String   @unique
  deviceName  String?
  trustToken  String   @unique
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String         @id @default(uuid())
  userId      String
  name        String
  keyHash     String         @unique
  expiresAt   DateTime?
  createdAt   DateTime       @default(now())
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopes      ApiKeyScope[]
}

model ApiScope {
  id          String         @id @default(uuid())
  name        String         @unique // e.g. "vps:read", "vps:write"
  description String?
  apiKeys     ApiKeyScope[]
}

model ApiKeyScope {
  apiKeyId String
  scopeId  String
  apiKey   ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  scope    ApiScope @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@id([apiKeyId, scopeId])
}

// Secret Management
model Secret {
  id                 String         @id @default(uuid())
  keyIdentifier      String         @unique // e.g. "proxmox.token.node1"
  valueEncrypted     String         // AES-256-GCM encrypted payload
  encryptionVersion  String         // e.g. "v1"
  lastRotated        DateTime       @default(now())
  lastVerified       DateTime?
  createdBy          String?
  updatedBy          String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

// Virtualization Infrastructure
model Node {
  id              String      @id @default(uuid())
  name            String      @unique
  hostname        String
  apiUrl          String
  apiToken        String
  sslFingerprint  String?
  cpuCores        Int         @default(0)
  memoryMb        Int         @default(0)
  storageGb       Int         @default(0)
  status          String      @default("offline") // "online" | "offline" | "maintenance"
  latency         Int         @default(0)
  version         String      @default("unknown")
  clusterName     String?
  maintenanceMode Boolean     @default(false)
  supportsLxc           Boolean     @default(true)
  supportsQemu          Boolean     @default(false)
  supportsNestedVirt    Boolean     @default(false)
  supportsUefi          Boolean     @default(false)
  supportsSecureBoot    Boolean     @default(false)
  supportsGpuPassthrough Boolean     @default(false)
  supportsPciPassthrough Boolean     @default(false)
  storagePools          String      @default("[\"default\"]") // JSON array of pools
  isoLibrary            String      @default("[]") // JSON array of ISO paths/names
  templates             String      @default("[]") // JSON array of templates
  cloudImages           String      @default("[]") // JSON array of images
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  instances       Instance[]
  tags            NodeTag[]
  isos            Iso[]
}

model Instance {
  id               String          @id @default(uuid())
  nodeId           String
  userId           String?
  vmid             Int
  name             String
  status           String          @default("stopped") // "running" | "stopped" | "suspended" | "starting" | "stopping"
  type             String          @default("LXC") // "LXC" | "QEMU" | "KVM"
  cpuCores         Int             @default(1)
  memoryMb         Int             @default(512)
  storageGb        Int             @default(10)
  ipAddress        String?
  gateway          String?
  osTemplate       String
  password         String?
  hostname         String
  notes            String?
  folderId         String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  node             Node            @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  user             User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  backups          Backup[]
  snapshots        Snapshot[]
  firewallRules    FirewallRule[]
  tags             InstanceTag[]
  automationTasks  AutomationTask[]
  vmConfig         VmConfiguration?
  lxcConfig        LxcConfiguration?
  cloudInit        CloudInit?
  networkInterfaces NetworkInterface[]
  disks            Disk[]
  pciDevices       PciDevice[]
}

model VirtualizationType {
  id          String   @id @default(uuid())
  name        String   @unique // e.g. "LXC", "QEMU", "KVM"
  displayName String
  description String?
}

model VmConfiguration {
  id                   String   @id @default(uuid())
  instanceId           String   @unique
  instance             Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  cpuThreads           Int      @default(1)
  cpuSockets           Int      @default(1)
  cpuModel             String   @default("host") // "host-passthrough" | "host-model" | "qemu64" | "custom"
  cpuFlags             String   @default("[]") // JSON array
  numa                 Boolean  @default(false)
  cpuPinning           String?
  cpuAffinity          String?
  nestedVirtualization Boolean  @default(false)
  hypervisorBit        Boolean  @default(true)
  hideHypervisor       Boolean  @default(false)
  cpuHotplug           Boolean  @default(false)
  cpuMode              String   @default("host-passthrough")
  customCpuModelId     String?
  smbiosManufacturer   String?
  smbiosProductName    String?
  smbiosVersion        String?
  smbiosSerialNumber   String?
  smbiosSku            String?
  smbiosFamily         String?
  smbiosUuid           String?
  smbiosOemStrings     String   @default("[]") // JSON array
  bootOrder            String   @default("[\"disk\"]") // JSON array
  uefi                 Boolean  @default(true)
  legacyBios           Boolean  @default(false)
  secureBoot           Boolean  @default(false)
  tpm                  Boolean  @default(false)
  machineType          String   @default("q35") // "q35" | "i440fx"
  efiVariables         String?
  bootDelay            Int      @default(0)
  graphicsType         String   @default("vnc") // "vnc" | "spice" | "serial"
  graphicsResolution   String   @default("1024x768")
  gpuType              String   @default("std") // "virtio" | "qxl" | "vga"
  exposeDevKvm         Boolean  @default(true)
  enableIntelVtx       Boolean  @default(true)
  enableAmdV           Boolean  @default(true)
  enableIommu          Boolean  @default(false)
  hugePages            Boolean  @default(false)
  memoryBallooning     Boolean  @default(true)
  watchdog             String?  // "default" | "reset" | "poweroff"
  guestAgent           Boolean  @default(true)
}

model LxcConfiguration {
  id                   String   @id @default(uuid())
  instanceId           String   @unique
  instance             Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  privileged           Boolean  @default(false)
  nesting              Boolean  @default(true)
}

model Iso {
  id        String   @id @default(uuid())
  name      String
  path      String
  sizeBytes BigInt?
  nodeId    String
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
}

model CloudInit {
  id            String   @id @default(uuid())
  instanceId    String   @unique
  instance      Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  enabled       Boolean  @default(false)
  userData      String?
  metaData      String?
  networkConfig String?
}

model NetworkInterface {
  id                String   @id @default(uuid())
  instanceId        String
  instance          Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  bridge            String   @default("lxdbr0")
  vlan              Int?
  macAddress        String
  firewallEnabled   Boolean  @default(false)
  bandwidthLimitIn  Int?
  bandwidthLimitOut Int?
  nicModel          String   @default("virtio") // "virtio", "e1000", "rtl8139", "vmxnet3"
  ipv4Address       String?
  ipv6Address       String?
  gateway           String?
  staticDhcp        Boolean  @default(false)
}

model Disk {
  id            String   @id @default(uuid())
  instanceId    String
  instance      Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  name          String
  sizeGb        Int
  type          String   @default("virtio") // "virtio", "sata", "scsi", "ide", "nvme"
  cacheMode     String   @default("none")
  discard       Boolean  @default(true)
  ioThreads     Boolean  @default(false)
  ssdEmulation  Boolean  @default(false)
  isIso         Boolean  @default(false)
  isoPath       String?
}

model PciDevice {
  id          String   @id @default(uuid())
  instanceId  String
  instance    Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  name        String
  type        String
  hostAddress String
  vendorId    String?
  deviceId    String?
}

model Tag {
  id         String        @id @default(uuid())
  name       String        @unique
  color      String        // HEX code
  instances  InstanceTag[]
  nodes      NodeTag[]
}

model InstanceTag {
  instanceId String
  tagId      String
  instance   Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([instanceId, tagId])
}

model NodeTag {
  nodeId String
  tagId  String
  node   Node @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([nodeId, tagId])
}

// Storage Abstraction
model StorageProvider {
  id             String   @id @default(uuid())
  name           String   @unique
  type           String   // "local" | "s3" | "r2" | "b2" | "sftp" | "nfs"
  secretId       String   // References Secret.keyIdentifier
  status         String   @default("active") // "active" | "inactive"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  backups        Backup[]
}

model Backup {
  id                String          @id @default(uuid())
  instanceId        String
  storageProviderId String
  name              String
  sizeBytes         Int             @default(0)
  status            String          @default("pending") // "pending" | "completed" | "failed"
  type              String          @default("manual") // "manual" | "scheduled"
  path              String?
  encryptionEnabled Boolean         @default(false)
  createdAt         DateTime        @default(now())
  instance          Instance        @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  storageProvider   StorageProvider @relation(fields: [storageProviderId], references: [id], onDelete: Cascade)
}

model Snapshot {
  id          String   @id @default(uuid())
  instanceId  String
  name        String
  description String?
  status      String   @default("active") // "active" | "restoring"
  createdAt   DateTime @default(now())
  instance    Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model FirewallRule {
  id         String   @id @default(uuid())
  instanceId String
  direction  String   // "inbound" | "outbound"
  action     String   // "ACCEPT" | "DROP" | "REJECT"
  protocol   String   // "tcp" | "udp" | "icmp"
  port       String?  // Port number or range
  sourceIp   String?  @default("0.0.0.0/0")
  createdAt  DateTime @default(now())
  instance   Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

// Monitoring & Audit
model AuditLog {
  id                 String   @id @default(uuid())
  requestId          String?  // Correlation ID
  sessionId          String?
  userId             String?
  username           String   @default("system")
  action             String   // e.g. "auth.login", "vps.reboot"
  details            String?
  severity           String   @default("info")
  targetResourceId   String?
  targetResourceType String?  // e.g. "Instance", "Node"
  previousState      String?  // JSON text representation
  newState           String?  // JSON text representation
  executionTimeMs    Int      @default(0)
  success            Boolean  @default(true)
  failureReason      String?
  httpMethod         String?
  endpoint           String?
  ipAddress          String?
  userAgent          String?
  country            String?  // GeoIP resolve
  createdAt          DateTime @default(now())
  user               User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Notification {
  id           String   @id @default(uuid())
  userId       String?
  title        String
  message      String
  category     String
  priority     String
  icon         String?
  color        String?
  read         Boolean  @default(false)
  createdAt    DateTime @default(now())
  readAt       DateTime?
  actionUrl    String?
  metadata     String?  // JSON string
  sourceEvent  String?
  expiration   DateTime?
  deliveries   NotificationDelivery[]
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationPreference {
  id                  String   @id @default(uuid())
  userId              String   @unique
  desktopEnabled      Boolean  @default(true)
  soundEnabled        Boolean  @default(true)
  soundProfile        String   @default("default") // "default" | "success" | "warning" | "error" | "critical" | "silent"
  emailEnabled        Boolean  @default(true)
  discordEnabled      Boolean  @default(true)
  discordWebhookUrl   String?
  webhookEnabled      Boolean  @default(true)
  webhookUrl          String? // Generic webhook
  mutedCategories     String   @default("[]") // JSON list of muted categories
  muteUntil           DateTime?
  retentionDays       Int      @default(30)
  eventPreferences    String   @default("{}") // JSON string of per-event channel settings
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationDelivery {
  id             String   @id @default(uuid())
  notificationId String
  channel        String   // "panel" | "websocket" | "email" | "discord" | "webhook"
  status         String   // "success" | "failed" | "pending"
  error          String?
  retryCount     Int      @default(0)
  maxAttempts    Int      @default(5)
  retryAfter     DateTime?
  deliveredAt    DateTime @default(now())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
}

model Announcement {
  id              String    @id @default(uuid())
  title           String
  message         String
  type            String    // "banner" | "maintenance" | "emergency"
  targetAudience  String    // "all" | "admins" | "roles" | "users"
  targetValue     String?   // comma-separated list of target role names or user IDs
  scheduledStart  DateTime?
  scheduledEnd    DateTime?
  createdAt       DateTime  @default(now())
}

// ============================================================
// Automation Engine Models
// ============================================================

// Task types as string (SQLite doesn't support enums):
// POWER_START, POWER_STOP, POWER_RESTART, POWER_FORCE_STOP, POWER_FREEZE, POWER_UNFREEZE
// STORAGE_BACKUP, STORAGE_SNAPSHOT, STORAGE_DELETE_OLD_BACKUPS, STORAGE_DELETE_OLD_SNAPSHOTS
// MAINTENANCE_REINSTALL_OS, MAINTENANCE_UPDATE_PACKAGES, MAINTENANCE_CHANGE_HOSTNAME
// EXECUTION_SHELL_COMMAND

// Schedule types: ONCE, DAILY, WEEKLY, MONTHLY, CUSTOM_CRON

model AutomationTask {
  id                String                  @id @default(uuid())
  name              String
  description       String?
  taskType          String                  // POWER_START, etc.
  scheduleType      String?                 // ONCE, DAILY, WEEKLY, MONTHLY, CUSTOM_CRON
  cronExpression    String?                 // Custom cron expression
  timezone          String                  @default("UTC")
  retries           Int                     @default(0)
  retryDelay        Int                     @default(60000) // ms between retries
  timeout           Int                     @default(300000) // max execution time in ms
  enabled           Boolean                 @default(true)
  notifyOnSuccess   Boolean                 @default(true)
  notifyOnFailure   Boolean                 @default(true)
  status            String                  @default("ACTIVE") // ACTIVE, INACTIVE, PAUSED
  
  // Task payload
  shellCommand      String?                 // For EXECUTION_SHELL_COMMAND
  hostname          String?                 // For MAINTENANCE_CHANGE_HOSTNAME
  deleteOlderThan   Int?                    // For delete old backups/snapshots (days)
  
  // Chain support
  parentTaskId      String?                 // Part of a task chain
  parentTask        AutomationTask?         @relation("TaskChain", fields: [parentTaskId], references: [id])
  childTasks        AutomationTask[]        @relation("TaskChain")
  chainStep         Int?                    // Order in chain
  stopOnFailure     Boolean                 @default(true)
  
  // Relations
  instanceId        String
  instance          Instance                @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  userId            String
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs              AutomationRun[]
  nextRunAt         DateTime?
  lastRunAt         DateTime?
  lastRunStatus     String?                 // QUEUED, RUNNING, COMPLETED, FAILED, CANCELLED, RETRYING
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([instanceId])
  @@index([userId])
  @@index([status])
  @@index([nextRunAt])
  @@index([parentTaskId])
}

model AutomationRun {
  id                String                  @id @default(uuid())
  taskId            String
  task              AutomationTask          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  status            String                  @default("QUEUED") // QUEUED, RUNNING, COMPLETED, FAILED, CANCELLED, RETRYING
  startedAt         DateTime?
  finishedAt        DateTime?
  duration          Int?                    // milliseconds
  exitCode          Int?
  consoleOutput     String?                 // Captured shell output
  errorMessage      String?
  triggeredBy       String                  @default("schedule") // "schedule" | "manual" | "chain"
  attempt           Int                     @default(1)
  maxAttempts       Int                     @default(1)
  
  // For manual runs
  triggeredByUserId String?
  logs              AutomationLog[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([taskId])
  @@index([status])
  @@index([createdAt])
}

model AutomationLog {
  id                String                  @id @default(uuid())
  runId             String
  run               AutomationRun           @relation(fields: [runId], references: [id], onDelete: Cascade)
  level             String                  @default("info") // "info" | "warn" | "error" | "debug"
  message           String
  timestamp         DateTime                @default(now())

  @@index([runId])
  @@index([timestamp])
}
